// 2. ローカルからSupabaseへ全てのデータを一括引っ越し（同期）させる関数
async function syncAllLocalToSupabase() {
    if (!myId || myId === "GUEST-000") return;

    // ローカルストレージにある全データを取得
    const uName = localStorage.getItem('core_v4_userName') || "プレイヤー1";
    const uTarget = localStorage.getItem('core_v4_userTarget') || "未設定";
    const uTitle = localStorage.getItem('core_v4_userTitle') || "称号なし";
    const uExp = parseInt(localStorage.getItem('core_v4_totalExp') || "0");
    const uChar = localStorage.getItem('core_v4_active_char') || "";
    const uWeapon = localStorage.getItem('core_v4_active_weapon') || "";
    const uArmor = localStorage.getItem('core_v4_active_armor') || "";
    const uAvatar = localStorage.getItem('core_v4_user_avatar_' + myId) || "";

    // 既存アカウント作成時の情報（リアル名、年齢、PIN）をローカルの全ユーザーリストから探す
    const allUsers = window.getAllUsers();
    const currentAccount = allUsers.find(u => u.id === myId) || {};

    const profileData = {
        id: myId,
        pin: currentAccount.pin || "0000", // 万が一なければ初期値
        player_name: uName,
        real_name: currentAccount.realName || uName,
        age: parseInt(currentAccount.age) || null,
        total_exp: uExp,
        my_target: uTarget,
        selected_title: uTitle,
        active_char: uChar,
        active_weapon: uWeapon,
        active_armor: uArmor,
        avatar_base64: uAvatar,
        updated_at: new Date()
    };

    // 1. プロフィールの保存（upsert = なければ新規作成、あれば上書き）
    await supabase.from('users').upsert(profileData);

    // 2. 単語帳の保存
    let storedWords = [];
    try { storedWords = JSON.parse(localStorage.getItem('core_v4_custom_words_' + myId) || "[]"); } catch(e){}
    
    await supabase.from('vocab_lists').upsert({
        user_id: myId,
        vocab_data: storedWords,
        updated_at: new Date()
    });

    console.log("[Supabase] 既存データの引っ越しアップロードが完了しました！");
}

// 3. データ変更時に裏側で「全自動・超高速・非同期リアルタイム保存」を行うフック処理
// 単語帳が変更された瞬間にクラウドにも自動保存
const originalSaveVocabToStorage = window.saveVocabToStorage;
window.saveVocabToStorage = function() {
    // まず元のLocalStorageへの保存を即座に実行（ユーザーの操作感をカクつかせない！）
    originalSaveVocabToStorage();
    
    if (!myId || myId === "GUEST-000") return;

    // 1歩遅れて裏側でSupabaseに非同期送信（自動保存）
    let storedWords = [];
    try { storedWords = JSON.parse(localStorage.getItem('core_v4_custom_words_' + myId) || "[]"); } catch(e){}
    
    supabase.from('vocab_lists').upsert({
        user_id: myId,
        vocab_data: storedWords,
        updated_at: new Date()
    }).then(({ error }) => {
        if (!error) console.log("[Supabase] 単語帳を自動同期しました。");
    });
};

