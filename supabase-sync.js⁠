    // ==========================================================================
    // 🌐 本物化機能 1: 全リアルユーザーのXPデータベースから真の世界ランキングを描画
    // ==========================================================================
    async function fetchAndRenderRealLeaderboard() {
        const container = document.getElementById('leaderboardContainer');
        if (!container) return;

        try {
            // users テーブルからXPが多い順に上位50名を取得
            const { data: serverUsers, error } = await sbClient
                .from('users')
                .select('id, player_name, selected_title, total_exp, avatar_base64')
                .order('total_exp', { ascending: false })
                .limit(50);

            if (error) throw error;

            let html = "";
            serverUsers.forEach((u, idx) => {
                let rankColor = idx === 0 ? "#FBBF24" : idx === 1 ? "#94A3B8" : idx === 2 ? "#D97706" : "#FFFFFF";
                let isMe = (u.id === myId);
                let bgStyle = isMe ? "background: linear-gradient(90deg, rgba(0, 240, 255, 0.15) 0%, rgba(15, 23, 42, 0.6) 100%); border: 1px solid var(--cosmic-cyan);" : "background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);";
                
                let lvlData = window.calculateLevelFromExp(u.total_exp || 0);
                
                let avatarUiNodeStr = `<span style="font-size:16px;">👤</span>`;
                if (u.avatar_base64) {
                    avatarUiNodeStr = `<img src="${u.avatar_base64}" style="width:24px; height:24px; border-radius:50%; object-fit:cover; border:1px solid var(--cosmic-cyan); box-shadow:0 0 6px var(--cosmic-cyan);">`;
                }

                html += `
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:8px 12px; border-radius:8px; margin-bottom:4px; ${bgStyle} font-size:12px;">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <span style="color:${rankColor}; font-weight:900; font-size:14px; width:18px; text-align:center;">${idx + 1}</span>
                            <div style="width:24px; height:24px; display:flex; align-items:center; justify-content:center;">${avatarUiNodeStr}</div>
                            <div>
                                <div style="font-weight:bold; color:white;">${u.player_name || "名無しの修行者"}${isMe ? " (あなた)" : ""} <span style="font-size:9px; color:var(--cosmic-cyan); font-weight:normal; margin-left:4px;">LV.${lvlData.level}</span></div>
                                <div style="font-size:9px; color:var(--text-sub); margin-top:1px;">${u.selected_title || "称号なし"}</div>
                            </div>
                        </div>
                        <div style="text-align:right; font-weight:900; color:var(--word-so); font-family:monospace;">${u.total_exp || 0} <span style="font-size:8px; color:var(--text-sub); font-weight:normal;">EXP</span></div>
                    </div>`;
            });

            container.innerHTML = html;
        } catch (err) {
            console.error("Failed to fetch real leaderboard:", err);
        }
    }

    // ==========================================================================
    // 🌐 本物化機能 2: 各出題モードごとのリアル世界ハイスコアランキングの描画
    // ==========================================================================
    async function fetchAndRenderRealGameLeaderboard() {
        const container = document.getElementById('leaderboardListContainer');
        if (!container) return;

        try {
            // 現在選択されている出題モード（currentLbMode）のスコアを高い順に取得
            const { data: scores, error } = await sbClient
                .from('game_scores')
                .select('user_id, player_name, high_score, updated_at')
                .eq('game_mode', currentLbMode)
                .order('high_score', { ascending: false })
                .limit(25);

            if (error) throw error;

            container.innerHTML = "";
            if (!scores || scores.length === 0) {
                container.innerHTML = `<div style="color:var(--text-sub); text-align:center; padding:20px 0;">このモードの全国スコア記録はまだありません。</div>`;
                return;
            }

            const rankColors = ["#FBBF24", "#94A3B8", "#D97706", "white", "white"];
            scores.forEach((record, index) => {
                let isMe = (record.user_id === myId);
                let bgStyle = isMe ? "background: linear-gradient(90deg, rgba(192, 132, 252, 0.15) 0%, rgba(15, 23, 42, 0.6) 100%); border-left: 3px solid var(--cosmic-purple-light);" : "border-bottom:1px solid rgba(255,255,255,0.05);";
                
                let dateObj = new Date(record.updated_at);
                let dateStr = `${dateObj.getMonth()+1}/${dateObj.getDate()} ${dateObj.getHours()}:${String(dateObj.getMinutes()).padStart(2,'0')}`;

                const row = document.createElement('div');
                row.style.cssText = `display:flex; justify-content:space-between; align-items:center; padding:6px 8px; ${bgStyle}`;
                
                row.innerHTML = `
                    <div style="display:flex; gap:12px; align-items:center;">
                        <span style="color:${rankColors[index] || 'white'}; font-weight:900; font-size:14px; width:18px; text-align:center;">${index + 1}</span>
                        <span style="color:white; font-weight:800; letter-spacing:0.5px;">${record.player_name || "無名プレイヤー"}${isMe ? " (あなた)" : ""}</span>
                    </div>
                    <div style="text-align:right;">
                        <span style="color:var(--cosmic-cyan); font-weight:900; font-family:monospace; font-size:13px; margin-right:8px;">${record.high_score} <span style="font-size:8px; font-weight:normal; color:var(--text-sub);">PTS</span></span>
                        <span style="color:var(--text-sub); font-size:9px; display:block; margin-top:1px;">${dateStr}</span>
                    </div>`;
                container.appendChild(row);
            });
        } catch (err) {
            console.error("Failed to fetch real game leaderboard:", err);
        }
    }
